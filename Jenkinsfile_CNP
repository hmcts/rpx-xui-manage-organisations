#!groovy

properties([
    [
        $class       : 'GithubProjectProperty',
        displayName  : 'Expert UI Manage Organisations',
        projectUrlStr: 'https://github.com/hmcts/rpx-xui-manage-organisations'
    ],
    pipelineTriggers([
        [$class: 'GitHubPushTrigger']
    ])
])

@Library("Infrastructure")

//To enable PACT testing on pipeline uncomment the next line
import uk.gov.hmcts.contino.AppPipelineDsl

def type      = "nodejs"
def product   = "xui"
def component = "mo-webapp"
def channel   = '#xui-pipeline'
def yarnBuilder = new uk.gov.hmcts.contino.YarnBuilder(this)

def publishPlaywrightE2EReport = { String reportName ->
    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "functional-output/tests/playwright-e2e/odhin-report",
        reportFiles          : 'xui-playwright-e2e.html',
        reportName           : reportName
    ])
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/**,test-results/**/*'
}

def publishPlaywrightApiReport = { String reportName ->
    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "functional-output/tests/playwright-api/odhin-report",
        reportFiles          : 'xui-mo-playwright-api.html',
        reportName           : reportName
    ])
    steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-api/**,test-results/**/*'
}

def secrets = [
  'rpx-${env}': [
    secret('test-user1-email', 'TEST_USER1_EMAIL'),
    secret('test-user1-password', 'TEST_USER1_PASSWORD'),
    secret('test-roo-username', 'TEST_ROO_EMAIL'),
    secret('test-roo-password', 'TEST_ROO_PASSWORD'),
    secret('test-user2-email', 'TEST_USER2_EMAIL'),
    secret('test-user2-password', 'TEST_USER2_PASSWORD'),
    secret('test-townley-email', 'TEST_TOWNLEY_EMAIL'),
    secret('test-townley-password', 'TEST_TOWNLEY_PASSWORD'),
    secret('test-api-email', 'TEST_API_EMAIL'),
    secret('test-api-password', 'TEST_API_PASSWORD'),
    secret('mo-s2s-client-secret', 'S2S_SECRET'),
    secret('xui-oauth2-token', 'IDAM_SECRET'),
    secret('appinsights-connection-string-mo', 'APPINSIGHTS_CONNECTION_STRING'),
    secret('google-analytics-key', 'GOOGLE_ANALYTICS_KEY'),
    secret('launch-darkly-client-id', 'LAUNCH_DARKLY_CLIENT_ID'),
    secret('system-user-name', 'SYSTEM_USER_NAME'),
    secret('system-user-password', 'SYSTEM_USER_PASSWORD'),
    secret('mo-webapp-redis6-connection-string', 'REDISCLOUD_URL'),

  ],
]

def branchesToSync = ['demo', 'perftest', 'ithc']

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [ $class: 'AzureKeyVaultSecret',
      secretType: 'Secret',
      name: secretName,
      version: '',
      envVariable: envVar
    ]
}

withPipeline(type, product, component) {
    disableCleanupOfHelmReleaseOnFailure()
    enableSlackNotifications(channel)
    loadVaultSecrets(secrets)
    enableAksStagingDeployment()
    syncBranchesWithMaster(branchesToSync)

   enablePactAs([
     AppPipelineDsl.PactRoles.CONSUMER
])

    afterAlways('checkout') {
        stage('Playwright Install Chromium') {
            try {
                yarnBuilder.yarn('test:setup:playwright-install-chromium')
            } catch (Error) {
                error(message: "${STAGE_NAME} is unstable: " + Error.toString())
            }
        }
    }

    afterSuccess('build') {
        yarnBuilder.yarn('build')
    }

    afterSuccess('test') {

        publishHTML ( [
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/coverage/node",
            reportFiles          : "index.html",
            reportName           : "node coverage tests"
        ])

        publishHTML ( [
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/coverage/ng",
            reportFiles          : "index.html",
            reportName           : "ng coverage tests"
        ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/a11y/",
            reportFiles          : 'Report.html',
            reportName           : 'Manage Org a11y Test'
        ])




    }

//    after('smoketest:demo') {
//        publishHTML([
//            allowMissing         : true,
//            alwaysLinkToLastBuild: true,
//            keepAll              : true,
//            reportDir            : "reports/tests/smoke/",
//            reportFiles          : 'index.html',
//            reportName           : 'DEMO Smoke Test'
//        ])
//    }

    afterAlways('smoketest:preview') {
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/api_functional/",
            reportFiles          : 'mochawesome.html',
            reportName           : 'PREVIEW API Test'
        ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "functional-output/tests/playwright-e2e/odhin-report",
            reportFiles          : 'xui-playwright-e2e.html',
            reportName           : 'PREVIEW Manage Org Smoke Test (Odhin)'
        ])

        steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/**,test-results/**/*'

        stage('Preview Playwright E2E') {
            withEnv([
                "FUNCTIONAL_TESTS_WORKERS=2",
                "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                "PLAYWRIGHT_SKIP_INSTALL=true"
            ]) {
                yarnBuilder.yarn('test:playwrightE2E:raw')
            }
            publishPlaywrightE2EReport('PREVIEW Manage Org Playwright E2E')
        }
    }

    afterSuccess('functionalTest:preview') {

      publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "reports/tests/api_functional/",
        reportFiles          : 'mochawesome.html',
        reportName           : 'PREVIEW API Functional Test'
      ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/functional/",
            reportFiles          : 'index.html',
            reportName           : 'PREVIEW Functional Test'
        ])

        stage('Preview Playwright API') {
            withEnv([
                "PLAYWRIGHT_SKIP_INSTALL=true"
            ]) {
                yarnBuilder.yarn('test:api:pw')
            }
            publishPlaywrightApiReport('PREVIEW Manage Org Playwright API')
        }
    }


    afterAlways('smoketest:aat') {
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/api_functional/",
            reportFiles          : 'mochawesome.html',
            reportName           : 'API Smoke Test'
        ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "functional-output/tests/playwright-e2e/odhin-report",
            reportFiles          : 'xui-playwright-e2e.html',
            reportName           : 'AAT Manage Org Smoke Test (Odhin)'
        ])

        steps.archiveArtifacts allowEmptyArchive: true, artifacts: 'functional-output/tests/playwright-e2e/**,test-results/**/*'

        stage('AAT Playwright E2E') {
            withEnv([
                "FUNCTIONAL_TESTS_WORKERS=2",
                "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                "PLAYWRIGHT_SKIP_INSTALL=true"
            ]) {
                yarnBuilder.yarn('test:playwrightE2E:raw')
            }
            publishPlaywrightE2EReport('AAT Manage Org Playwright E2E')
        }
    }

    afterSuccess('functionalTest:aat') {

      publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : "reports/tests/api_functional/",
        reportFiles          : 'mochawesome.html',
        reportName           : 'API Functional Test'
      ])

        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "reports/tests/functional/",
            reportFiles          : 'index.html',
            reportName           : 'AAT Functional Test'
        ])

        stage('AAT Playwright API') {
            withEnv([
                "PLAYWRIGHT_SKIP_INSTALL=true"
            ]) {
                yarnBuilder.yarn('test:api:pw')
            }
            publishPlaywrightApiReport('AAT Manage Org Playwright API')
        }
    }

}
