def runPlaywrightFunctionalTestsInParallel = { String environmentName ->
    stage("${environmentName} Functional Tests (Parallel)") {
        parallel(
            failFast: true,
            api: {
                stage('API Tests') {
                    try {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=4",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            yarnBuilder.yarn('test:api:pw')
                        }
                    } catch (Exception e) {
                        echo "[failFast] API Tests catch: ${e.getClass().getName()}: ${e.getMessage()}"
                        if (handleFailFastAbort(e)) { return }
                        throw e
                    } finally {
                        publishPlaywrightApiReport("${environmentName} Manage Org Playwright API")
                    }
                }
            },
            playwrightIntegration: {
                stage('Playwright Integration Tests') {
                    try {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=4",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            yarnBuilder.yarn('test:playwright:integration')
                        }
                    } catch (Exception e) {
                        echo "[failFast] Playwright Integration Tests catch: ${e.getClass().getName()}: ${e.getMessage()}"
                        if (handleFailFastAbort(e)) { return }
                        throw e
                    } finally {
                        publishPlaywrightIntegrationReport("${environmentName} Manage Org Playwright Integration")
                    }
                }
            },
            playwrightE2E: {
                stage('Playwright E2E') {
                    try {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=2",
                            "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            yarnBuilder.yarn('test:playwrightE2E:raw')
                        }
                    } catch (Exception e) {
                        echo "[failFast] Playwright E2E catch: ${e.getClass().getName()}: ${e.getMessage()}"
                        if (handleFailFastAbort(e)) { return }
                        throw e
                    } finally {
                        publishPlaywrightE2EReport("${environmentName} Manage Org Playwright E2E")
                    }
                }
            }
        )
    }
}

