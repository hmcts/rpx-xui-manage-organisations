def publishPlaywrightAccessibilityReport = { String reportName ->
    try {
        ensureHtmlReportForPublishing(
            "${playwrightAccessibilityOutputRoot}/odhin-report",
            'xui-playwright-accessibility.html',
            reportName
        )
        publishHTML([
            allowMissing         : true,
            alwaysLinkToLastBuild: true,
            keepAll              : true,
            reportDir            : "${playwrightAccessibilityOutputRoot}/odhin-report",
            reportFiles          : 'xui-playwright-accessibility.html',
            reportName           : reportName
        ])
    } catch (Exception e) {
        currentBuild.result = 'UNSTABLE'
        echo "[playwright-accessibility] Report publish failed; marking build unstable because this pack must publish Odhín evidence: ${e.getClass().getName()}: ${e.getMessage()}"
    }
    try {
        stagePlaywrightArtifacts("${playwrightAccessibilityOutputRoot}/stable-artifacts", 'test-results/playwright-accessibility')
        catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
            publishPlaywrightJUnit("${playwrightAccessibilityOutputRoot}/**/*junit.xml")
        }
        steps.archiveArtifacts(
            allowEmptyArchive: true,
            artifacts: "${playwrightAccessibilityOutputRoot}/**"
        )
    } catch (Exception e) {
        currentBuild.result = 'UNSTABLE'
        echo "[playwright-accessibility] Evidence publish failed; marking build unstable because this pack must publish accessibility evidence: ${e.getClass().getName()}: ${e.getMessage()}"
    }
}

def runPlaywrightFunctionalTestsInParallel = { String environmentName ->
    stage("${environmentName} Functional Tests (Parallel)") {
        try {
            def functionalSuites = [
                failFast: false,
                api: {
                    stage('API Tests') {
                        try {
                            withEnv(playwrightBrowsersEnv() + [
                                "API_PW_INCLUDE_TAGS=${params.API_PW_INCLUDE_TAGS ?: ''}",
                                "API_PW_EXCLUDED_TAGS_OVERRIDE=${params.API_PW_EXCLUDED_TAGS_OVERRIDE ?: ''}",
                                "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES ? 'true' : 'false'}",
                                "FUNCTIONAL_TESTS_WORKERS=6",
                                "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-api",
                                "PLAYWRIGHT_HTML_OUTPUT=functional-output/tests/playwright-api/html-report",
                                "PLAYWRIGHT_JUNIT_OUTPUT=functional-output/tests/playwright-api/playwright-api-junit.xml",
                                "PLAYWRIGHT_SKIP_INSTALL=true"
                            ]) {
                                yarnBuilder.yarn('test:api:pw:raw')
                            }
                        } catch (Exception e) {
                            echo "[parallel] API Tests catch: ${e.getClass().getName()}: ${e.getMessage()}"
                            if (handleParallelInterruption(e)) { return }
                            throw e
                        } finally {
                            publishPlaywrightApiReport("${environmentName} Manage Org Playwright API")
                        }
                    }
                },
                playwrightIntegration: {
                    stage('Playwright Integration Tests') {
                        try {
                            withEnv(playwrightBrowsersEnv() + [
                                "INTEGRATION_PW_INCLUDE_TAGS=${params.INTEGRATION_PW_INCLUDE_TAGS ?: ''}",
                                "INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE=${params.INTEGRATION_PW_EXCLUDED_TAGS_OVERRIDE ?: ''}",
                                "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES ? 'true' : 'false'}",
                                "FUNCTIONAL_TESTS_WORKERS=6",
                                "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-integration",
                                "PLAYWRIGHT_JUNIT_OUTPUT=functional-output/tests/playwright-integration/playwright-integration-junit.xml",
                                "PLAYWRIGHT_SKIP_INSTALL=true"
                            ]) {
                                yarnBuilder.yarn('test:playwright:integration:raw')
                            }
                        } catch (Exception e) {
                            echo "[parallel] Playwright Integration Tests catch: ${e.getClass().getName()}: ${e.getMessage()}"
                            if (handleParallelInterruption(e)) { return }
                            throw e
                        } finally {
                            publishPlaywrightIntegrationReport("${environmentName} Manage Org Playwright Integration")
                        }
                    }
                },
                playwrightE2E: {
                    stage('Playwright E2E') {
                        try {
                            withEnv(playwrightBrowsersEnv() + [
                                "FUNCTIONAL_TESTS_WORKERS=6",
                                "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-e2e",
                                "PLAYWRIGHT_JUNIT_OUTPUT=functional-output/tests/playwright-e2e/playwright-e2e-junit.xml",
                                "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                                "PLAYWRIGHT_TAGS=${params.E2E_PW_INCLUDE_TAGS ?: '@e2e'}",
                                "PLAYWRIGHT_EXCLUDE_TAGS=${params.E2E_PW_EXCLUDED_TAGS_OVERRIDE ?: '@a11y'}",
                                "E2E_PW_INCLUDE_TAGS=${params.E2E_PW_INCLUDE_TAGS ?: ''}",
                                "E2E_PW_EXCLUDED_TAGS_OVERRIDE=${params.E2E_PW_EXCLUDED_TAGS_OVERRIDE ?: ''}",
                                "PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES=${params.PLAYWRIGHT_IGNORE_GLOBAL_EXCLUDES ? 'true' : 'false'}",
                                "PLAYWRIGHT_SKIP_INSTALL=true"
                            ]) {
                                yarnBuilder.yarn('test:playwrightE2E:raw')
                            }
                        } catch (Exception e) {
                            echo "[parallel] Playwright E2E catch: ${e.getClass().getName()}: ${e.getMessage()}"
                            if (handleParallelInterruption(e)) { return }
                            throw e
                        } finally {
                            publishPlaywrightE2EReport("${environmentName} Manage Org Playwright E2E")
                        }
                    }
                }
            ]

            if (params.RUN_PLAYWRIGHT_ACCESSIBILITY) {
                functionalSuites = [failFast: false]
                functionalSuites.playwrightAccessibility = {
                    stage('Playwright Accessibility Tests') {
                        try {
                            withEnv(playwrightBrowsersEnv() + [
                                "FUNCTIONAL_TESTS_WORKERS=6",
                                "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-accessibility",
                                "PLAYWRIGHT_JUNIT_OUTPUT=${playwrightAccessibilityOutputRoot}/playwright-accessibility-junit.xml",
                                "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                                "PLAYWRIGHT_SKIP_INSTALL=true"
                            ]) {
                                yarnBuilder.yarn('test:accessibility:playwright')
                            }
                        } catch (Exception e) {
                            if (handleParallelInterruption(e)) { return }
                            currentBuild.result = 'UNSTABLE'
                            echo "[parallel-report-gathering] Playwright Accessibility failed; marking build unstable so a manual accessibility-only run cannot hide missing Odhín evidence: ${e.getClass().getName()}: ${e.getMessage()}"
                        } finally {
                            publishPlaywrightAccessibilityReport("${environmentName} Manage Org Playwright Accessibility")
                        }
                    }
                }
            } else {
                echo '[playwright-accessibility] CNP stage omitted by default. Set RUN_PLAYWRIGHT_ACCESSIBILITY=true on a manual build to run only this pack.'
            }

            parallel(functionalSuites)
        } finally {
            publishManageOrgEvidenceDashboard("${environmentName} Manage Org Playwright Evidence")
        }
    }
}

