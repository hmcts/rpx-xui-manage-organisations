    disableCleanupOfHelmReleaseOnFailure()
    enableSlackNotifications(channel)
    loadVaultSecrets(secrets)
    enableAksStagingDeployment()
    syncBranchesWithMaster(branchesToSync)

   enablePactAs([
     AppPipelineDsl.PactRoles.CONSUMER
])

    afterSuccess('checkout') {
        stage('Yarn Install') {
            withEnv(playwrightBrowsersEnv()) {
                yarnBuilder.yarn('install --immutable')
                sh 'touch .yarn_dependencies_installed'
            }
        }
    }

    afterAlways('checkout') {
        stage('Playwright Install Chromium') {
            try {
                withEnv(playwrightBrowsersEnv()) {
                    sh '''
                        mkdir -p "$PLAYWRIGHT_BROWSERS_PATH"
                        if [ ! -f .yarn_dependencies_installed ]; then
                          node .yarn/releases/yarn-4.9.2.cjs install --immutable
                          touch .yarn_dependencies_installed
                        fi
                        node .yarn/releases/yarn-4.9.2.cjs test:setup:playwright-install-chromium
                        node .yarn/releases/yarn-4.9.2.cjs test:setup:playwright-verify-chromium
