static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
  [ $class: 'AzureKeyVaultSecret',
    secretType: 'Secret',
    name: secretName,
    version: '',
    envVariable: envVar
  ]
}

def ensureHtmlReportForPublishing = { String reportDir, String reportFile, String suiteName ->
    withEnv([
        "PW_ODHIN_ENSURE_REPORT_DIR=${reportDir}",
        "PW_ODHIN_ENSURE_REPORT_FILE=${reportFile}",
        "PW_ODHIN_ENSURE_SUITE_NAME=${suiteName}"
    ]) {
        sh '''
            node scripts/ensure-odhin-report.js \
              --report-dir "$PW_ODHIN_ENSURE_REPORT_DIR" \
              --report-file "$PW_ODHIN_ENSURE_REPORT_FILE" \
              --suite-name "$PW_ODHIN_ENSURE_SUITE_NAME"
        '''
    }
}

def publishPlaywrightReport = { String reportDir, String reportFile, String reportName, String artifacts ->
    ensureHtmlReportForPublishing(reportDir, reportFile, reportName)
    publishHTML([
        allowMissing         : true,
        alwaysLinkToLastBuild: true,
        keepAll              : true,
        reportDir            : reportDir,
        reportFiles          : reportFile,
        reportName           : reportName
    ])
    archiveArtifacts allowEmptyArchive: true, artifacts: artifacts
}

def runPlaywrightFunctionalTests = { String environmentName ->
    stage("${environmentName} Playwright Functional Replacement") {
        try {
            parallel(
                failFast: true,
                api: {
                    stage('API Tests') {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=4",
                            "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-api",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            sh 'yarn test:api:pw'
                        }
                    }
                },
                playwrightIntegration: {
                    stage('Playwright Integration Tests') {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=4",
                            "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-integration",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            sh 'yarn test:playwright:integration'
                        }
                    }
                },
                playwrightA11y: {
                    stage('Playwright Accessibility Tests') {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=4",
                            "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-a11y",
                            "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            sh 'yarn test:a11y:playwright'
                        }
                    }
                },
                playwrightE2E: {
                    stage('Playwright E2E') {
                        withEnv([
                            "FUNCTIONAL_TESTS_WORKERS=2",
                            "PLAYWRIGHT_TEST_OUTPUT_DIR=test-results/playwright-e2e",
                            "PW_SESSION_CAPTURE_FAILURE_TTL_MS=0",
                            "PLAYWRIGHT_TAGS=@e2e",
                            "PLAYWRIGHT_EXCLUDE_TAGS=@a11y",
                            "PLAYWRIGHT_SKIP_INSTALL=true"
                        ]) {
                            sh 'yarn test:playwrightE2E:raw'
                        }
                    }
                }
            )
        } finally {
            publishPlaywrightReport(
                "functional-output/tests/playwright-api/odhin-report",
                'xui-mo-playwright-api.html',
                "${environmentName} Manage Org Playwright API",
                'functional-output/tests/playwright-api/**'
            )
            publishPlaywrightReport(
                "functional-output/tests/playwright-integration/odhin-report",
                'xui-mo-playwright-integration.html',
                "${environmentName} Manage Org Playwright Integration",
                'functional-output/tests/playwright-integration/**'
            )
            publishPlaywrightReport(
                "functional-output/tests/playwright-a11y/odhin-report",
                'xui-playwright-a11y.html',
                "${environmentName} Manage Org Register Organisation Playwright A11y",
                'functional-output/tests/playwright-a11y/**'
            )
            publishPlaywrightReport(
                "functional-output/tests/playwright-e2e/odhin-report",
                'xui-playwright-e2e.html',
                "${environmentName} Manage Org Playwright E2E",
                'functional-output/tests/playwright-e2e/**'
            )
        }
    }
}

